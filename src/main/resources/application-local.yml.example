# 이 파일을 복사해서 application-local.yml로 만들고, 실제 값으로 채워서 사용하세요.
# application-local.yml은 .gitignore에 등록되어 있어 커밋되지 않습니다.

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/smartcare?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: your_password_here
    driver-class-name: com.mysql.cj.jdbc.Driver

  data:
    redis:
      host: localhost
      port: 6379

jwt:
  secret: change-this-to-a-long-random-base64-secret-at-least-256-bits
  access-token-expiration: 3600000       # 1시간 (ms)
  refresh-token-expiration: 1209600000   # 14일 (ms)
